# ─────────────────────────────────────────────────────────────
# Noreon — configuration d'environnement (exemple)
# Copier vers .env et adapter. Ne jamais committer le vrai .env.
# ─────────────────────────────────────────────────────────────

# --- Base de données interne de Noreon (métadonnées, profils, logs) ---
NOREON_DATABASE_URL=postgresql+psycopg://noreon:noreon@localhost:5432/noreon

# --- Redis (files de tâches asynchrones) ---
NOREON_REDIS_URL=redis://localhost:6379/0

# --- Clé de chiffrement des credentials sources (AES-256) ---
# Générer avec:  python -c "import secrets,base64;print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
# En production: coffre de secrets (Vault, KMS…). Ne jamais logger.
NOREON_SECRET_KEY=CHANGE_ME_generate_a_32_byte_urlsafe_base64_key

# --- Couche d'abstraction LLM ---
# Fournisseur par défaut du tenant: heuristic | openai | anthropic | mistral
NOREON_LLM_PROVIDER=heuristic
NOREON_LLM_MODEL=
# Clés (facultatives — le provider "heuristic" fonctionne hors-ligne, sans clé)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=

# --- Garde-fous d'exécution SQL (valeurs par défaut, configurables par tenant) ---
NOREON_SQL_TIMEOUT_SECONDS=60
NOREON_SQL_ROW_LIMIT=10000
NOREON_SQL_MAX_COST=1000000
NOREON_SQL_MAX_CONCURRENT_PER_CONNECTION=1

# --- Profilage ---
NOREON_PROFILING_SAMPLE_THRESHOLD=1000000
NOREON_PROFILING_SAMPLE_SIZE=100000

# --- Divers ---
NOREON_ENV=development
NOREON_CORS_ORIGINS=http://localhost:3000
